<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_disc"
    android:padding="8dp">

    <!-- Circle center play button -->
    <ImageButton
        android:id="@+id/btn_play_pause"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_centerInParent="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play_widget"
        android:scaleType="centerInside"
        android:contentDescription="Play/Pause" />

    <!-- Volume Down button on left -->
    <ImageButton
        android:id="@+id/btn_vol_down"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_volume_down_widget"
        android:scaleType="centerInside"
        android:tint="#CCFF5252"
        android:contentDescription="Volume Down" />

    <!-- Volume Up button on right -->
    <ImageButton
        android:id="@+id/btn_vol_up"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_volume_up_widget"
        android:scaleType="centerInside"
        android:tint="#CC00E676"
        android:contentDescription="Volume Up" />

    <!-- Compact info badge -->
    <TextView
        android:id="@+id/widget_song_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btn_play_pause"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="4dp"
        android:gravity="center"
        android:text="Mahnı"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:singleLine="true" />

    <TextView
        android:id="@+id/widget_song_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btn_play_pause"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Disc"
        android:textColor="#00E676"
        android:textSize="9sp"
        android:singleLine="true" />
</RelativeLayout>
