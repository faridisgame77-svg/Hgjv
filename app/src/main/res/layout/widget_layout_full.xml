<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_full"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Row: Album image and Track Meta -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_headphones_widget"
            android:tint="#80f7b7"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/widget_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seçilmiş Mahnı"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_song_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Musiqiçi"
                android:textColor="#888c9a"
                android:textSize="11sp"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Current volume info on the top right -->
        <TextView
            android:id="@+id/widget_volume_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Səs: 70%"
            android:textColor="#80f7b7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#15ffffff"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <!-- Mid Row: Fake progress line visual indicator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2.5dp"
        android:background="#20ffffff"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Bottom Row: Transport controls with dedicated Volume Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5">

        <!-- Vol Down -->
        <ImageButton
            android:id="@+id/btn_vol_down"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_volume_down_widget"
            android:scaleType="centerInside"
            android:tint="#FFFF5252"
            android:contentDescription="Volume Down" />

        <!-- Prev -->
        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev_widget"
            android:scaleType="centerInside"
            android:contentDescription="Prev Song" />

        <!-- Play/Pause -->
        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play_widget"
            android:scaleType="centerInside"
            android:contentDescription="Play or Pause" />

        <!-- Next -->
        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next_widget"
            android:scaleType="centerInside"
            android:contentDescription="Next Song" />

        <!-- Vol Up -->
        <ImageButton
            android:id="@+id/btn_vol_up"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_volume_up_widget"
            android:scaleType="centerInside"
            android:tint="#FF00E676"
            android:contentDescription="Volume Up" />

    </LinearLayout>
</LinearLayout>
