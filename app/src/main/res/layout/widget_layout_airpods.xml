<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_airpods"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_headphones_widget"
            android:tint="#80f7b7"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/widget_airpods_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AirPods Pro"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVE"
            android:textColor="#00E676"
            android:textSize="8sp"
            android:textStyle="bold"
            android:background="#2000e676"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Column 1: Battery Levels -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_battery_l"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Left Ear: 88%"
                android:textColor="#cccccc"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_battery_r"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Right Ear: 92%"
                android:textColor="#cccccc"
                android:textSize="11sp"
                android:layout_marginTop="3dp" />

            <TextView
                android:id="@+id/widget_battery_case"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Case level: 100%"
                android:textColor="#858c9b"
                android:textSize="10sp"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Column 2: Button cluster -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Vol Down -->
            <ImageButton
                android:id="@+id/btn_vol_down"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_volume_down_widget"
                android:scaleType="centerInside"
                android:tint="#77ffffff" />

            <!-- Play/Pause -->
            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_play_widget"
                android:scaleType="centerInside"
                android:layout_marginStart="4dp" />

            <!-- Vol Up -->
            <ImageButton
                android:id="@+id/btn_vol_up"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_volume_up_widget"
                android:scaleType="centerInside"
                android:tint="#77ffffff"
                android:layout_marginStart="4dp" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
