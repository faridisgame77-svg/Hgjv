<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_retro"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#FF2A85"
        android:src="@drawable/ic_headphones_widget"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:layout_marginStart="4dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retro Music"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_song_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FM-84 Synthwave"
            android:textColor="#00E676"
            android:textSize="10sp"
            android:singleLine="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginEnd="4dp">

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev_widget"
            android:scaleType="centerInside"
            android:contentDescription="Prev Song" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play_widget"
            android:scaleType="centerInside"
            android:contentDescription="Play/Pause"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next_widget"
            android:scaleType="centerInside"
            android:contentDescription="Next Song"
            android:layout_marginStart="4dp" />
    </LinearLayout>
</LinearLayout>
